<% layout("/layouts/boilerplate") %>

    <!-- <h3 class="mt-3">All Listings</h3> -->
    <!-- <form action="/listings/new" method="get">
        <button>Create New listing</button>
    </form> -->
<style>

    #filters{
        display: flex;
        align-items: center;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        padding-bottom: 1rem;
        scrollbar-width: none;
    }

    #filters::-webkit-scrollbar{
        display: none;
    }

    .filter{
        text-align: center;
        margin-right: 2rem;
        margin-top: 1rem;
        opacity: 0.7;
        min-width: 80px;
        flex-shrink: 0;
    }

    .filter:hover{
        opacity: 1;
        cursor: pointer;
    }

    .filter p{
        font-size: 0.8rem;
    }

    .active-filter{
        opacity: 1 !important;
        border-bottom: 2px solid black;
    }

    .tax-info{
        display: none;
    }

    .tax-toggle{
        border: 1px solid black;
        border-radius: 1rem;
        padding: 0.8rem 1rem;
        margin-left: 2rem;
        display: flex;
        align-items: center;
        flex-shrink: 0;
        white-space: nowrap;
    }

</style>

<div id="filters">
  <!-- All option -->
   <a href="/listings" class="filter text-decoration-none text-dark <%= !selectedCategory ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-border-all"></i></div>
    <p>All</p>
  </a>

  <a href="/listings?category=Trending" class="filter text-decoration-none text-dark <%= selectedCategory === 'Trending' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </a>

  <a href="/listings?category=Rooms" class="filter text-decoration-none text-dark<%= selectedCategory === 'Rooms' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </a>

  <a href="/listings?category=Iconic Cities" class="filter text-decoration-none text-dark <%= selectedCategory === 'Iconic Cities' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-mountain-city"></i></div>
    <p>Iconic Cities</p>
  </a>

  <a href="/listings?category=Mountains" class="filter text-decoration-none text-dark <%= selectedCategory === 'Mountains' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountains</p>
  </a>

  <a href="/listings?category=Castles" class="filter text-decoration-none text-dark <%= selectedCategory === 'Castles' ? 'active-filter' : '' %>">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    <p>Castles</p>
  </a>

  <a href="/listings?category=Amazing Pools" class="filter text-decoration-none text-dark <%= selectedCategory === 'Amazing Pools' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Amazing Pools</p>
  </a>

  <a href="/listings?category=Camping" class="filter text-decoration-none text-dark <%= selectedCategory === 'Camping' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </a>

  <a href="/listings?category=Farms" class="filter text-decoration-none text-dark <%= selectedCategory === 'Farms' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-cow"></i></div>
    <p>Farms</p>
  </a>

  <a href="/listings?category=Arctic" class="filter text-decoration-none text-dark <%= selectedCategory === 'Arctic' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-snowflake"></i></div>
    <p>Arctic</p>
  </a>

  <a href="/listings?category=Domes" class="filter text-decoration-none text-dark <%= selectedCategory === 'Domes' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-igloo"></i></div>
    <p>Domes</p>
  </a>

  <a href="/listings?category=Boats" class="filter text-decoration-none text-dark <%= selectedCategory === 'Boats' ? 'active-filter' : '' %>">
    <div><i class="fa-solid fa-ship"></i></div>
    <p>Boats</p>
  </a>

  <div class="tax-toggle">
    <div class="form-check form-switch m-0">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label ms-2" for="switchCheckDefault">Display total after Taxes</label>
    </div>
  </div>
</div>

    <h3 class="mt-3 ms-2">
  <% if (typeof query !== "undefined" && query && query.trim() !== "") { %>
    Search Results for "<%= query %>"
  <% } else { %>
    <% if(selectedCategory) { %>

    <%= selectedCategory %> Listings

<% } else { %>

    All Listings

<% } %>
<% } %>
</h3>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
      <!-- this has been changed while adding category field -->
      <% if (allListings.length === 0) { %>

        <p class="ms-3">

            <% if (query && query.trim() !== "") { %>

                No listings found for "<%= query %>".

            <% } else if (selectedCategory && selectedCategory.trim() !== "") { %>

                No listings found in "<%= selectedCategory %>" category.

            <% } else { %>

                No listings found.

            <% } %>

        </p>

      <% } else { %>

        <% for(let listing of allListings) { %>

          <a href="/listings/<%= listing._id %>" class="listing-link">

              <div class="card col listing-card">
                  <img src="<%= listing.image.url %>" class="card-img-top" alt="listing" style="height: 20rem">

                  <div class="card-img-overlay"></div>

                  <div class="card-body">
                      <p class="card-text">
                          <b><%= listing.title %></b>
                          <br>

                          &#8377; <%= listing.price.toLocaleString("en-IN") %> / night

                          &nbsp; &nbsp;

                          <i class="tax-info">+18% GST</i>
                      </p>
                   </div>
               </div>

          </a>

        <% } %>
      <% } %>
    </div>
<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click",() => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for(info of taxInfo){
            if(info.style.display != "inline"){
                info.style.display ="inline";
            }else{
                info.style.display = "none";
            }
        }
    });

   
</script>
